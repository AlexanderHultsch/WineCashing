# Kopiere nach .env und trage echte Werte ein. .env ist gitignored — NIEMALS committen!
# Im Pi-Server-Konstrukt liegt die .env nur auf dem Pi (apps/winecashing/.env)
# und wird per env_file in den Container gereicht.

# Port, auf dem die App lauscht (Caddy proxied intern dorthin)
PORT=3000

# Pfad der SQLite-Datei. Im Container: /data/winecashing.db (Bind-Mount
# ./data/winecashing:/data -> wandert automatisch ins naechtliche Backup).
DB_PATH=./data/winecashing.db

# Session-Secret fuer Owner-Login-Cookies (Pflicht in Produktion!).
# Erzeugen z. B. mit:  openssl rand -base64 32
SESSION_SECRET=<<LANGES_ZUFAELLIGES_SECRET>>

# Einmaliger Admin-Seed (npm run seed:admin liest diese Werte). Der Admin-Account wird
# zentral einmal gesetzt und ist über alle Seiten des Pi-Konstrukts identisch.
ADMIN_USER=admin
ADMIN_PASSWORD=<<SICHERES_PASSWORT>>

# Optional: Cookie-Secure-Flag erzwingen — nur einschalten, wenn die App
# selbst direkt ueber HTTPS ausgeliefert wird (hinter Cloudflare/Caddy: aus lassen).
# SECURE_COOKIES=true

# Optional: Anzahl vertrauenswuerdiger Reverse-Proxy-Hops (Default 1).
# TRUST_PROXY=1
