# Kopiere nach .env und passe die Werte an. .env ist gitignored.

# Server
PORT=3000

# Owner-Session (httpOnly-Cookie, Vertrag A.1).
# In Produktion ein langes, zufälliges Secret setzen!
SESSION_SECRET=change-me-in-production

# SQLite-Datei (siehe db/index.js)
WINE_DB_PATH=./data/wine.sqlite

# Admin-Bootstrap für `npm run seed:admin` (Vertrag A.3)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me
